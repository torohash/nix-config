{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "rm *": "ask",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~*": "deny",
      "rm -rf $HOME*": "deny",
      "rm -fr /": "deny",
      "rm -fr /*": "deny",
      "rm -fr ~*": "deny",
      "rm -fr $HOME*": "deny",
      "rm -r /": "deny",
      "rm -r /*": "deny",
      "rm -r ~*": "deny",
      "rm -r $HOME*": "deny",
      "rm --recursive /": "deny",
      "rm --recursive /*": "deny",
      "rm --recursive ~*": "deny",
      "rm --recursive $HOME*": "deny"
    }
  },
  "agent": {
    "build": {
      "permission": {
        "read": "allow",
        "doom_loop": "allow",
        "external_directory": "allow"
      }
    }
  }
}
